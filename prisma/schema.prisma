generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  OWNER
  ADMIN
  COMERCIAL
  FINANCE
  USER
}

enum EmailTokenType {
  VERIFICATION
  CHANGE
}

enum EntityType {
  INDIVIDUAL
  COMPANY
}

// ─── Auth tokens ─────────────────────────────────────────────────────────────

model EmailToken {
  id        String         @id @default(cuid())
  token     String         @unique
  type      EmailTokenType
  userId    String         @map("user_id")
  newEmail  String?        @map("new_email")
  expiresAt DateTime       @map("expires_at")
  createdAt DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// ─── Address ─────────────────────────────────────────────────────────────────

model Address {
  id           String  @id @default(cuid())
  zip          String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  country      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company?
  user     User?
  supplier Supplier?
  customer Customer?

  @@map("addresses")
}

// ─── Company ─────────────────────────────────────────────────────────────────

model Company {
  id                    String   @id @default(cuid())
  legalName             String   @map("legal_name")
  tradeName             String   @map("trade_name")
  taxId                 String   @unique @map("tax_id")
  stateRegistration     String?  @map("state_registration")
  municipalRegistration String?  @map("municipal_registration")
  email                 String   @unique
  phoneCountryCode      String   @default("55") @map("phone_country_code")
  phone                 String
  isActive              Boolean  @default(true) @map("is_active")

  addressId String?  @unique @map("address_id")
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("companies")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id                  String    @id @default(cuid())
  firstName           String    @map("first_name")
  lastName            String    @map("last_name")
  email               String    @unique
  password            String?
  role                Role      @default(USER)
  nationalId          String?   @map("national_id")
  birthDate           DateTime? @map("birth_date")
  phoneCountryCode    String    @default("55") @map("phone_country_code")
  phone               String?
  isActive            Boolean   @default(true) @map("is_active")
  emailVerified       DateTime? @map("email_verified")
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")

  addressId String?  @unique @map("address_id")
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  emailTokens         EmailToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

// ─── Supplier ────────────────────────────────────────────────────────────────

model SupplierCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  suppliers Supplier[]

  @@map("supplier_categories")
}

model Supplier {
  id                    String     @id @default(cuid())
  entityType            EntityType @map("entity_type")
  name                  String
  tradeName             String     @map("trade_name")
  birthDate             DateTime?  @map("birth_date")
  taxId                 String     @map("tax_id")
  stateRegistration     String?    @map("state_registration")
  municipalRegistration String?    @map("municipal_registration")
  email                 String
  phoneCountryCode      String     @default("55") @map("phone_country_code")
  phone                 String
  notes                 String?
  isActive              Boolean    @default(true) @map("is_active")

  categoryId String?           @map("category_id")
  category   SupplierCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  addressId String?  @unique @map("address_id")
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

// ─── Customer ────────────────────────────────────────────────────────────────

model CustomerCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  customers Customer[]

  @@map("customer_categories")
}

model Customer {
  id                    String     @id @default(cuid())
  entityType            EntityType @map("entity_type")
  name                  String
  tradeName             String     @map("trade_name")
  birthDate             DateTime?  @map("birth_date")
  taxId                 String     @map("tax_id")
  stateRegistration     String?    @map("state_registration")
  municipalRegistration String?    @map("municipal_registration")
  email                 String
  phoneCountryCode      String     @default("55") @map("phone_country_code")
  phone                 String
  notes                 String?
  isActive              Boolean    @default(true) @map("is_active")

  categoryId String?           @map("category_id")
  category   CustomerCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  addressId String?  @unique @map("address_id")
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("customers")
}
